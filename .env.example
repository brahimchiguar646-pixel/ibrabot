# ============================================================
# IBRABOT PRO — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- REQUIRED ----

# Telegram bot token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_token_here

# OpenRouter API key (openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here

# ---- OPTIONAL: Admin Panel ----

# Secret token to access the admin panel at localhost:3000
# Default: ibrabot-admin-token (change in production)
ADMIN_TOKEN=ibrabot-admin-token

# ---- OPTIONAL: Canva Integration ----
# Create an app at https://www.canva.com/developers and generate a token
CANVA_API_KEY=your_canva_api_key_here

# ---- OPTIONAL: WhatsApp Business Integration ----
# Requires Meta Business account and approved WhatsApp Business API access
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token_here
